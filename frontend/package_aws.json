{
  "name": "bme-dooh-frontend-aws",
  "version": "2.0.0",
  "description": "Big Mann Entertainment DOOH Platform with AWS Integration",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "react-router-dom": "^6.20.1",
    "web-vitals": "^2.1.4",
    "axios": "^1.6.2",
    "lucide-react": "^0.294.0",
    "tailwindcss": "^3.3.6",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "aws-amplify": "^6.15.6",
    "@aws-amplify/ui-react": "^6.12.0",
    "@aws-amplify/ui-components": "^3.0.25",
    "ethers": "^6.15.0",
    "web3": "^4.16.0",
    "@metamask/sdk": "^0.26.5",
    "@walletconnect/web3-provider": "^1.8.0",
    "recharts": "^2.8.0",
    "react-chartjs-2": "^5.2.0",
    "chart.js": "^4.4.0",
    "mapbox-gl": "^2.15.0",
    "react-map-gl": "^7.1.6",
    "@mapbox/mapbox-gl-geocoder": "^5.0.1",
    "react-dropzone": "^14.2.3",
    "react-cropper": "^2.3.3",
    "cropperjs": "^1.6.1",
    "react-player": "^2.13.0",
    "react-virtualized": "^9.22.5",
    "react-window": "^1.8.8",
    "react-infinite-scroll-component": "^6.1.0",
    "framer-motion": "^10.16.16",
    "react-spring": "^9.7.3",
    "react-transition-group": "^4.4.5",
    "react-helmet-async": "^1.3.0",
    "react-error-boundary": "^4.0.11",
    "react-hook-form": "^7.48.2",
    "yup": "^1.4.0",
    "@hookform/resolvers": "^3.3.2",
    "react-query": "^3.39.3",
    "zustand": "^4.4.7",
    "immer": "^10.0.3",
    "lodash-es": "^4.17.21",
    "date-fns": "^2.30.0",
    "react-datepicker": "^4.24.0",
    "react-select": "^5.8.0",
    "react-hot-toast": "^2.4.1",
    "react-loading-skeleton": "^3.3.1",
    "react-lazyload": "^3.2.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "amplify:push": "amplify push",
    "amplify:pull": "amplify pull",
    "amplify:status": "amplify status",
    "amplify:mock": "amplify mock",
    "deploy": "amplify publish",
    "build:prod": "GENERATE_SOURCEMAP=false react-scripts build",
    "analyze": "npm run build && npx bundle-analyzer build/static/js/*.js",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,json,css,md}",
    "type-check": "tsc --noEmit"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "warn",
      "react-hooks/exhaustive-deps": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/lodash-es": "^4.17.12",
    "@types/mapbox-gl": "^2.7.17",
    "typescript": "^5.2.2",
    "eslint": "^8.54.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "bundle-analyzer": "^4.0.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "proxy": "http://localhost:8001"
}